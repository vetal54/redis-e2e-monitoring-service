<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="projectId" value="${projectId:-${GOOGLE_CLOUD_PROJECT}}"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.google.cloud.spring.logging.StackdriverJsonLayout">
                <projectId>${projectId}</projectId>
                <includeExceptionInMessage>false</includeExceptionInMessage>
                <includeException>true</includeException>
            </layout>
        </encoder>
    </appender>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="ch.qos.logback.classic.PatternLayout">
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %green([%level]) %yellow([%thread]) [%cyan(%logger{5}).%green(%M\(%F:%L\))] %cyan(traceId)=%green(%X{traceId:-?}) %cyan(spanId)=%green(%X{spanId:-?}) %m%n</pattern>
            </layout>
        </encoder>
    </appender>

    <if condition='isDefined("KUBERNETES_SERVICE_PORT")'>
        <then>
            <logger name="org.springframework" level="INFO" additivity="false">
                <appender-ref ref="CONSOLE_JSON"/>
            </logger>
            <logger name="com.redis" level="INFO" additivity="false">
                <appender-ref ref="CONSOLE_JSON"/>
            </logger>
            <logger name="reactor" level="INFO" additivity="false">
                <appender-ref ref="CONSOLE_JSON"/>
            </logger>
            <logger name="io.netty" level="INFO" additivity="false">
                <appender-ref ref="CONSOLE_JSON"/>
            </logger>
            <logger name="io.netty.util" level="ERROR"/>
            <root level="ERROR" additivity="false">
                <appender-ref ref="CONSOLE_JSON"/>
            </root>
        </then>
        <else>
            <logger name="org.springframework" level="INFO" additivity="false">
                <appender-ref ref="STDOUT"/>
            </logger>
            <logger name="com.redis" level="INFO" additivity="false">
                <appender-ref ref="STDOUT"/>
            </logger>
            <logger name="reactor" level="INFO" additivity="false">
                <appender-ref ref="STDOUT"/>
            </logger>
            <logger name="io.netty" level="INFO" additivity="false">
                <appender-ref ref="STDOUT"/>
            </logger>
            <logger name="io.netty.util" level="ERROR"/>
            <root level="ERROR" additivity="false">
                <appender-ref ref="STDOUT"/>
            </root>
        </else>
    </if>
</configuration>